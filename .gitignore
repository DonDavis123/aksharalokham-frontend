# ================================================================
#  Aksharalokam AI  ──  Frontend .gitignore
# ================================================================

# ── Secrets (NEVER commit these) ────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Dependencies ────────────────────────────────────────────────
node_modules/

# ── Vite build output ───────────────────────────────────────────
dist/
dist-ssr/

# ── Firebase CLI internals ───────────────────────────────────────
.firebase/
.firebaserc
firebase-debug.log
firestore-debug.log
ui-debug.log

# ── Editor & OS junk ────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Logs ────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing & coverage ──────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ────────────────────────────────────────────────────────
*.local
.cache/
